{
  "name": "backend-stellar-api",
  "version": "1.0.0",
  "description": "API para interactuar con contrato inteligente Stellar",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "db:up": "docker compose -f ../docker-compose.yml up -d mysql",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:test": "node scripts/test-db.js",
    "db:seed": "node scripts/seed-db.js",
    "db:setup": "npm run db:up && node scripts/seed-db.js"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.0"
  }
}
